# =============================================================================
# 8gent — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/8gent

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Clerk) — get keys from clerk.com dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# LLM Providers — get keys from each provider's console
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...

# Stripe — get keys from stripe.com dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CONNECT_CLIENT_ID=ca_...
STRIPE_PRICE_INDIVIDUAL=price_...
STRIPE_PRICE_PRO=price_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=notifications@8gentc.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Jobs
CRON_SECRET=your-cron-secret-here

# File Storage (DigitalOcean Spaces)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=8gent-uploads
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# Internal service URLs
ENGINE_API_URL=http://localhost:3001
LLM_GATEWAY_URL=http://localhost:3002
AGENT_HOST_URL=http://localhost:3003

# Service-to-service auth — generate a shared secret (e.g. openssl rand -hex 32)
# PLATFORM_C_SERVICE_TOKEN is used by Platforms A/B when calling the Engine API
# SERVICE_API_KEY is checked by the Engine to authenticate incoming s2s calls
# These must match: PLATFORM_C_SERVICE_TOKEN (on caller) == SERVICE_API_KEY (on engine)
PLATFORM_C_SERVICE_TOKEN=
SERVICE_API_KEY=

# Platform B URL — used by Platform C engine to call contractor APIs (dispatch, offers)
PLATFORM_B_URL=http://localhost:3010

# App URLs
NEXT_PUBLIC_CONSUMER_URL=http://localhost:3000
NEXT_PUBLIC_CONTRACTOR_URL=http://localhost:3010
NEXT_PUBLIC_ADMIN_URL=http://localhost:3020

# Environment
NODE_ENV=development
